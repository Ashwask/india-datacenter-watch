{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "IndiaDatacenter",
  "description": "One data center facility in India. One row per facility/campus, not per operator.",
  "type": "object",
  "required": ["id", "name", "operator", "city", "state", "latitude", "longitude", "status"],
  "properties": {
    "id": {
      "type": "string",
      "description": "Stable slug, e.g. 'mh-navimumbai-yotta-nm1'."
    },
    "name": { "type": "string", "description": "Facility name as published by the operator." },
    "operator": { "type": "string", "description": "Company that operates the facility." },
    "city": { "type": "string" },
    "state": { "type": "string", "description": "Indian state / UT." },
    "latitude": { "type": "number", "minimum": 6, "maximum": 38 },
    "longitude": { "type": "number", "minimum": 68, "maximum": 98 },
    "status": {
      "type": "string",
      "enum": ["operational", "under_construction", "proposed", "community_reported", "decommissioned"]
    },
    "it_load_mw": {
      "type": ["number", "null"],
      "description": "Published or reported critical IT load in MW. Null where undisclosed."
    },
    "commissioned_year": { "type": ["integer", "null"] },
    "water_stressed": {
      "type": ["boolean", "null"],
      "description": "Whether the facility sits in a region flagged water-stressed (e.g. WRI India). Null = unknown."
    },
    "notes": { "type": ["string", "null"] },
    "source": { "type": ["string", "null"], "description": "URL backing the figures in this row." }
  }
}
